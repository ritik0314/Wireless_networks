// JavaScript program to display reading status of books

var library = [
{
    author: 'Bill Gates',
    title: 'The Road Ahead',
    readingStatus: true
},
{
    author: 'Steve Jobs',
    title: 'Walter Isaacson',
    readingStatus: true
},
{
    author: 'Suzanne Collins',
    title: 'Mockingjay: The Final Book of The Hunger Games',
    readingStatus: false
}
];

// Loop through library array
for (var i = 0; i < library.length; i++) {

    console.log("Book Name: " + library[i].title);
    console.log("Author: " + library[i].author);
    console.log("Reading Status: " + library[i].readingStatus);
    console.log("----------------------------");
}