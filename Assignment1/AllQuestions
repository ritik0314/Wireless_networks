<!-- ========================= -->
<!-- Question 3: Text Formatting Tags in Table -->
<!-- ========================= -->

<!DOCTYPE html>
<html>

<head>
    <title>Formatting Tags</title>
</head>

<body>

    <h2>HTML Formatting Tags</h2>

    <table border="1">

        <tr>
            <th>Tag</th>
            <th>Example</th>
        </tr>

        <tr>
            <td>Bold</td>
            <td><b>This is Bold Text</b></td>
        </tr>

        <tr>
            <td>Italic</td>
            <td><i>This is Italic Text</i></td>
        </tr>

        <tr>
            <td>Underline</td>
            <td><u>This is Underline Text</u></td>
        </tr>

        <tr>
            <td>Strong</td>
            <td><strong>Important Text</strong></td>
        </tr>

        <tr>
            <td>Emphasis</td>
            <td><em>Emphasized Text</em></td>
        </tr>

    </table>

</body>

</html>



